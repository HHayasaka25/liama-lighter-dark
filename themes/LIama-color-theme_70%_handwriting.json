// https://code.visualstudio.com/api/references/theme-color
{
	"name": "LIama Zen",
	"type": "dark",
	"semanticHighliting": true, // 要素の意味によって色分け
	// 意味ごとの配色
	"semanticTokenColors": {
		"namespace": "#b1aeae",
		"property": "#b1aeae",
		"class": "#62a770",
		"struct": "#62a770",
		"type": "#62a770",
		"enum": "#62a770",
		"enumMember": {
			"foreground": "#b1aeae"
		},
		"variable.constant": {
			"foreground": "#bc7f7f"
		},
		"variable.defaultLibrary": {
			"foreground": "#ada97c"
		}
	},
	"colors": {
		// ====================
		//     コード領域の色
		// ====================
		"editor.background": "#212121",
		"editor.foreground": "#b1aeae",
		"editorLinenumber.foreground": "#3e3e3e",
		"editorLinenumber.activeForeground": "#b1aeae",
		"editor.selectionBackground": "#3e3e3e",
		// かっこの色
		"editorBracketHighlight.foreground1": "#6ca1b3",
		"editorBracketHighlight.foreground2": "#ada97c",
		"editorBracketHighlight.foreground3": "#a184ae",
		"editorBracketHighlight.foreground4": "#6ca1b3",
		"editorBracketHighlight.foreground5": "#ada97c",
		"editorBracketHighlight.foreground6": "#a184ae",
		"editorBracketHighlight.unexpectedBracket.foreground": "#bc7f7f",
		"editorError.foreground": "#bc7f7f",
		"editorWarning.foreground": "#ada97c",
		// =====================
		//     ベースカラー
		// =====================
		"selection.background": "#3e3e3e",
		"errorForeground": "#bc7f7f",
		"list.errorForeground": "#bc7f7f",
		"list.warningForeground": "#ada97c",
		// =====================
		// サイドバー（エクスプローラー、Gitなど。Ctrl+Bで表示を切り替えられる領域）
		// =====================
		"sideBar.background": "#212121",
		"sidebar.foreground": "#b1aeae",
		"sidebar.SectionHeader.background": "#3e3e3e", // 後ほど決定
		// ミニマップ（右側に表示されるコードの全体図）
		// 特に設定しない
		// =========================================
		// Editor Groups & Tabs（開いているファイル一覧）
		// =========================================
		"tab.activeBackground": "#212121",
		"tab.inactiveBackground": "#212121",
		"editorGroup.dropBackground": "#3e3e3e",
		"tab.activeBoader": "#b1aeae",
		"tab.selectedForeground": "#b1aeae",
		"tab.dropAndDropBoader": "#3e3e3e",
		"tab.inActiveForeground": "#3e3e3e",
		// ==========================
		//    パネル（統合ターミナル）
		// ==========================
		"panel.background": "#212121",
		"panelTitle.activeForeground": "#b1aeae",
		"panelTitle.inActiveForeground": "#3e3e3e",
		"panelTitle.activeBoader": "#b1aeae",
		"panelTitleBadge.background": "#796082",
		"panelTitleBadge.foreground": "#212121",
		// ===========================
		//     ステータスバー（最下部）
		// ===========================
		"statusBar.background": "#212121",
		"statusBar.foreground": "#b1aeae",
		"statusBar.noFolderBackground": "#212121",
		"statusBarItem.remoteBackground": "#212121",
		"statusBarItem.remoteForeground": "#b1aeae",
		"statuBarItem.errorForeground": "#bc7f7f",
		"statuBarItem.warningForeground": "#ada97c",
		// ===================================
		//     アクティビティバー（左端のアイコンが縦に並んでいる領域）
		// ===================================
		"activityBar.background": "#212121",
		"ActivityBarBadge.background": "#796082",
		"ActivityBarBadge.foreground": "#212121",
		// ===================================
		//     メニューバー（ファイル(F)など）
		// ===================================
		"menu.background": "#212121",
		"menu.foreground": "#b1aeae",
		"menu.selectionBackground": "#3e3e3e",
		"menu.selectedForeground": "#b1aeae",
		// =======================
		//     タイトルバー
		// =======================
		"titleBar.activeBackground": "#212121",
		"titleBar.inActiveBackground": "#212121",
		// =======================
		//     コマンドセンター
		// =======================
		"commandCenter.background": "#3e3e3e",
		"commandCenter.boader": "#3e3e3e",
		// =======================
		//     通知
		// =======================
		"notifications.background": "#3e3e3e",
		// =======================
		//     統合ターミナル
		// =======================
		"terminal.background": "#212121",
		"terminal.foreground": "#b1aeae",
		// 黒: システムログのタイムスタンプ、非アクティブなテキスト
		"terminal.ansiBlack": "#383838",
		// 赤: エラーメッセージ、git diff の削除行 (-)、壊れたリンク
		"terminal.ansiRed": "#bc7f7f",
		// 緑: 成功メッセージ、git diff の追加行 (+)、実行権限のあるファイル
		"terminal.ansiGreen": "#62a770",
		// 黄: 警告メッセージ、検索結果のハイライト、コマンドのオプション
		"terminal.ansiYellow": "#ada97c",
		// 青: ディレクトリ名 (ls)、プロンプトのホスト名、プライマリ情報
		"terminal.ansiBlue": "#6ca1b3",
		// マゼンタ: git のブランチ名、タグ名、特殊な実行ファイル
		"terminal.ansiMagenta": "#a184ae",
		// シアン: シンボリックリンク、URL、パスのセグメント
		"terminal.ansiCyan": "#598798",
		// 白: 標準的な出力テキスト、プロンプトのユーザー名
		"terminal.ansiWhite": "#b1aeae",
		// =================
		//     ウィンドウ
		// =================
		"window.activeBorder": "#00000000",
		"window.inActiveBorder": "#00000000"
	},
	"tokenColors": [
		{
			"name": "Base",
			"scope": [
				"variable",
				"support.variable",
				"text",
				"source",
				"punctuation"
			],
			"settings": {
				"foreground": "#b1aeae"
			}
		},
		{
			"name": "Function",
			"scope": [
				"entity.name.function",
				"storage.type",
				"storage.modifier"
			],
			"settings": {
				"foreground": "#6ca1b3"
			}
		},
		{
			"name": "Keyword",
			"scope": [
				"keyword.control",
				"meta.preprocessor",
				"punctuation.definition.keyword",
				"punctuation.definition.directive",
				"punctuation.definition.tag",
				"constant.language"
			],
			"settings": {
				"foreground": "#a184ae"
			}
		},
		{
			"name": "String",
			"scope": [
				"string",
				"punctuation.definition.string"
			],
			"settings": {
				"foreground": "#bc916f"
			}
		},
		{
			"name": "Number",
			"scope": [
				"constant.numeric"
			],
			"settings": {
				"foreground": "#bc7f7f"
			}
		},
		{
			"name": "Comment",
			"scope": [
				"comment",
				"punctuation.definition.comment"
			],
			"settings": {
				"foreground": "#797979"
			}
		},
		{
			"name": "C++ Standard Streams and Shift Operators",
			"scope": [
				"support.variable.mains.cpp",
				"support.variable.mains.c",
				"keyword.operator.shift.cpp",
				"keyword.operator.shift.c"
			],
			"settings": {
				"foreground": "#ada97c"
			}
		}
	]
}