{
  "name": "Lighter Dark - Zen Perceptual",
  "type": "dark",
  "semanticHighlighting": true,
  "semanticTokenColors": {
    "namespace": "#908e8e",
    "property": "#908e8e",
    "class": "#447e4f",
    "struct": "#447e4f",
    "type": "#447e4f",
    "enum": "#447e4f",
    "enumMember": {
      "foreground": "#908e8e"
    },
    "variable.constant": {
      "foreground": "#885739"
    },
    "variable.defaultLibrary": {
      "foreground": "#787554"
    }
  },
  "colors": {
    "editor.background": "#1e1e1e",
    "editor.foreground": "#908e8e",
    // --- 背景色の完全統一 ---
    "sideBar.background": "#1e1e1e",
    "activityBar.background": "#1e1e1e",
    "statusBar.background": "#1e1e1e",
    "panel.background": "#1e1e1e",
    "tab.activeBackground": "#1e1e1e",
    "tab.inactiveBackground": "#1e1e1e",
    "editorGroupHeader.tabsBackground": "#1e1e1e",
    "titleBar.activeBackground": "#1e1e1e",
    "titleBar.inactiveBackground": "#1e1e1e",
    "editorWidget.background": "#1e1e1e",
    "quickInput.background": "#1e1e1e",
    "breadcrumb.background": "#1e1e1e",
    "menu.background": "#1e1e1e",
    // --- 境界線 ---
    "sideBar.border": "#282828",
    "activityBar.border": "#282828",
    "panel.border": "#282828",
    "statusBar.border": "#282828",
    "editorGroup.border": "#282828",
    "editorWidget.border": "#282828",
    "tab.border": "#1e1e1e",
    "tab.activeBorder": "#908e8e",
    "tab.activeBorderTop": "#1e1e1e",
    // --- 基本のUI文字色 ---
    "sideBar.foreground": "#757575",
    "statusBar.foreground": "#656565",
    "tab.activeForeground": "#908e8e",
    "tab.inactiveForeground": "#656565",
    "panelTitle.activeForeground": "#908e8e",
    "panelTitle.inactiveForeground": "#656565",
    "titleBar.activeForeground": "#757575",
    "titleBar.inactiveForeground": "#555555",
    "menu.foreground": "#757575",
    "descriptionForeground": "#656565",
    // ========================================================
    // ▼ 今回の修正：ボタンの明度を少し下げ、文字を黒抜き（#1e1e1e）に変更
    // ========================================================
    "button.background": "#8e69ac",
    "button.foreground": "#1e1e1e",
    "button.hoverBackground": "#9f7abf",
    // ========================================================
    // ▼ バッジやリンクなどは「元のキーワードの紫」
    "badge.background": "#796082",
    "badge.foreground": "#1e1e1e",
    "activityBarBadge.background": "#796082",
    "activityBarBadge.foreground": "#1e1e1e",
    "textLink.foreground": "#796082",
    "textLink.activeForeground": "#908e8e",
    "inputOption.activeBorder": "#796082",
    // ▼ セカンダリボタン（キャンセルなど）は目立たないグレーのまま
    "button.secondaryBackground": "#222222",
    "button.secondaryForeground": "#757575",
    "button.secondaryHoverBackground": "#282828",
    "focusBorder": "#282828",
    "input.background": "#1e1e1e",
    "input.foreground": "#908e8e",
    "input.border": "#282828",
    "dropdown.background": "#1e1e1e",
    "dropdown.foreground": "#908e8e",
    "dropdown.border": "#282828",
    "checkbox.background": "#1e1e1e",
    "checkbox.foreground": "#908e8e",
    "checkbox.border": "#282828",
    // --- エクスプローラーのGit色・アイコン ---
    "gitDecoration.modifiedResourceForeground": "#757575",
    "gitDecoration.untrackedResourceForeground": "#757575",
    "gitDecoration.addedResourceForeground": "#757575",
    "gitDecoration.conflictingResourceForeground": "#7e5858",
    "gitDecoration.deletedResourceForeground": "#7e5858",
    "gitDecoration.ignoredResourceForeground": "#404040",
    "icon.foreground": "#555555",
    "tree.indentGuidesStroke": "#282828",
    "tree.inactiveIndentGuidesStroke": "#222222",
    // --- ステータスバー ---
    "statusBarItem.prominentBackground": "#1e1e1e",
    "statusBarItem.prominentForeground": "#656565",
    "statusBarItem.remoteBackground": "#1e1e1e",
    "statusBarItem.remoteForeground": "#656565",
    "statusBarItem.hoverBackground": "#282828",
    "activityBar.foreground": "#908e8e",
    "activityBar.inactiveForeground": "#454545",
    "activityBar.activeBorder": "#1e1e1e",
    // --- ホバーや選択のハイライト ---
    "list.hoverBackground": "#ffffff0a",
    "list.inactiveSelectionBackground": "#ffffff0a",
    "list.activeSelectionBackground": "#ffffff14",
    "list.activeSelectionForeground": "#908e8e",
    "list.inactiveSelectionForeground": "#757575",
    "list.hoverForeground": "#908e8e",
    "list.highlightForeground": "#908e8e",
    "breadcrumb.foreground": "#656565",
    "breadcrumb.focusForeground": "#908e8e",
    "breadcrumb.activeSelectionForeground": "#908e8e",
    // --- エディタ内のハイライト ---
    "editor.lineHighlightBackground": "#ffffff08",
    "editor.lineHighlightBorder": "#00000000",
    "editor.selectionBackground": "#ffffff1a",
    "editor.inactiveSelectionBackground": "#ffffff0d",
    "editor.selectionHighlightBackground": "#ffffff15",
    "editor.wordHighlightBackground": "#ffffff1a",
    "editor.wordHighlightStrongBackground": "#ffffff22",
    "editor.findMatchBackground": "#88573960",
    "editor.findMatchHighlightBackground": "#88573930",
    "editorBracketMatch.background": "#ffffff12",
    "editorBracketMatch.border": "#ffffff30",
    "editorLineNumber.foreground": "#404040",
    "editorLineNumber.activeForeground": "#908e8e",
    "editorCursor.foreground": "#908e8e",
    "editorError.foreground": "#8c5353",
    "editorWarning.foreground": "#85764d",
    "editorInfo.foreground": "#507886",
    "editorBracketHighlight.foreground1": "#507886",
    "editorBracketHighlight.foreground2": "#787554",
    "editorBracketHighlight.foreground3": "#796082",
    "editorBracketHighlight.foreground4": "#507886",
    "editorBracketHighlight.foreground5": "#787554",
    "editorBracketHighlight.foreground6": "#796082",
    "editorBracketHighlight.unexpectedBracket.foreground": "#7e5858"
  },
  "tokenColors": [
    {
      "name": "1. Variables & Base",
      "scope": [
        "variable",
        "support.variable",
        "text",
        "source"
      ],
      "settings": {
        "foreground": "#908e8e"
      }
    },
    {
      "name": "2. Functions & Modifiers",
      "scope": [
        "entity.name.function",
        "storage.type",
        "storage.modifier"
      ],
      "settings": {
        "foreground": "#507886"
      }
    },
    {
      "name": "3. Types & Classes",
      "scope": [
        "support.type",
        "storage.type"
      ],
      "settings": {
        "foreground": "#447e4f"
      }
    },
    {
      "name": "4. Strings",
      "scope": [
        "string",
        "punctuation.definition.string"
      ],
      "settings": {
        "foreground": "#826449"
      }
    },
    {
      "name": "5. Keywords",
      "scope": [
        "keyword.control",
        "meta.preprocessor",
        "keyword.control.directive",
        "punctuation.definition.directive",
        "constant.language"
      ],
      "settings": {
        "foreground": "#796082"
      }
    },
    {
      "name": "6. Numbers",
      "scope": [
        "constant.numeric"
      ],
      "settings": {
        "foreground": "#7e5858"
      }
    },
    {
      "name": "7. Punctuation",
      "scope": [
        "punctuation"
      ],
      "settings": {
        "foreground": "#908e8e"
      }
    },
    {
      "name": "operators",
      "scope": [
        "keyword.operator"
      ],
      "settings": {
        "foreground": "#787554"
      }
    },
    {
      "name": "Comments",
      "scope": [
        "comment",
        "punctuation.definition.comment"
      ],
      "settings": {
        "foreground": "#555555"
      }
    }
  ]
}