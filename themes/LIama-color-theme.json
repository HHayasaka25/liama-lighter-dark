{
  "name": "Lighter Dark - Zen Perceptual",
  "type": "dark",
  "semanticHighlighting": true,
  "semanticTokenColors": {
    "namespace": "#8d8a8a", // [最終調整] 知覚明度 (L*) = 57%
    "property": "#8d8a8a", // [最終調整] L* = 57%
    "class": "#50955e", // [知覚補正] L* = 56% (彩度による浮きを抑制)
    "struct": "#50955e", // [知覚補正] L* = 56%
    "type": "#50955e", // [知覚補正] L* = 56%
    "enum": "#50955e", // [知覚補正] L* = 56%
    "enumMember": {
      "foreground": "#8d8a8a"
    },
    "variable.constant": {
      "foreground": "#af7046" // [知覚補正] L* = 52% (暖色の進出性を抑制)
    },
    "variable.defaultLibrary": {
      "foreground": "#89855f" // [知覚補正] L* = 55% (黄色の眩しさを抑制)
    }
  },
  "colors": {
    "editor.background": "#1e1e1e",
    "editor.foreground": "#8d8a8a", // 知覚明度 (L*) = 57%
    // --- 背景色 ---
    "sideBar.background": "#1e1e1e",
    "activityBar.background": "#1e1e1e",
    "statusBar.background": "#1e1e1e",
    "panel.background": "#1e1e1e",
    "tab.activeBackground": "#1e1e1e",
    "tab.inactiveBackground": "#1e1e1e",
    "editorGroupHeader.tabsBackground": "#1e1e1e",
    "titleBar.activeBackground": "#1e1e1e",
    "titleBar.inactiveBackground": "#1e1e1e",
    "editorWidget.background": "#252525",
    "quickInput.background": "#252525",
    "quickInput.foreground": "#949494",
    "quickInputList.focusBackground": "#333333",
    "quickInputList.focusForeground": "#949494",
    "breadcrumb.background": "#1e1e1e",
    "menu.background": "#252525",
    "menu.selectionBackground": "#333333",
    "menu.selectionForeground": "#949494",
    "menu.separatorBackground": "#383838",
    // --- 通知・エラー表示 ---
    "notifications.background": "#252525",
    "notifications.foreground": "#949494",
    "notifications.border": "#383838",
    "notificationsErrorIcon.foreground": "#af7272",
    "notificationsWarningIcon.foreground": "#89855f",
    "notificationsInfoIcon.foreground": "#5e8d9e",
    // --- 境界線 ---
    "sideBar.border": "#282828",
    "activityBar.border": "#282828",
    "panel.border": "#282828",
    "statusBar.border": "#282828",
    "editorGroup.border": "#282828",
    "editorWidget.border": "#282828",
    "tab.border": "#1e1e1e",
    "tab.activeBorder": "#8d8a8a",
    "tab.activeBorderTop": "#1e1e1e",
    // --- UI文字色 ---
    "sideBar.foreground": "#949494",
    "statusBar.foreground": "#888888",
    "tab.activeForeground": "#949494",
    "tab.inactiveForeground": "#888888",
    "panelTitle.activeForeground": "#949494",
    "panelTitle.inactiveForeground": "#888888",
    "titleBar.activeForeground": "#949494",
    "titleBar.inactiveForeground": "#787878",
    "menu.foreground": "#949494",
    "descriptionForeground": "#888888",
    // --- ボタン・アクセント ---
    "button.background": "#9578a1", // [知覚補正] 紫系の L* = 55%
    "button.foreground": "#1e1e1e",
    "button.hoverBackground": "#a384b1",
    "badge.background": "#9578a1",
    "badge.foreground": "#1e1e1e",
    "activityBarBadge.background": "#9578a1",
    "activityBarBadge.foreground": "#1e1e1e",
    "textLink.foreground": "#9578a1",
    "textLink.activeForeground": "#8d8a8a",
    "inputOption.activeBorder": "#9578a1",
    // --- その他UI ---
    "button.secondaryBackground": "#222222",
    "button.secondaryForeground": "#949494",
    "button.secondaryHoverBackground": "#282828",
    "focusBorder": "#282828",
    "input.background": "#2a2a2a",
    "input.foreground": "#949494",
    "input.border": "#454545",
    "dropdown.background": "#1e1e1e",
    "dropdown.foreground": "#949494",
    "dropdown.border": "#282828",
    "checkbox.background": "#1e1e1e",
    "checkbox.foreground": "#949494",
    "checkbox.border": "#282828",
    "gitDecoration.modifiedResourceForeground": "#949494",
    "gitDecoration.untrackedResourceForeground": "#949494",
    "gitDecoration.addedResourceForeground": "#949494",
    "gitDecoration.conflictingResourceForeground": "#af7272",
    "gitDecoration.deletedResourceForeground": "#af7272",
    "gitDecoration.ignoredResourceForeground": "#555555",
    "icon.foreground": "#787878",
    "tree.indentGuidesStroke": "#282828",
    "tree.inactiveIndentGuidesStroke": "#222222",
    "statusBarItem.prominentBackground": "#1e1e1e",
    "statusBarItem.prominentForeground": "#888888",
    "statusBarItem.remoteBackground": "#1e1e1e",
    "statusBarItem.remoteForeground": "#888888",
    "statusBarItem.hoverBackground": "#282828",
    "activityBar.foreground": "#949494",
    "activityBar.inactiveForeground": "#555555",
    "activityBar.activeBorder": "#1e1e1e",
    "list.activeSelectionForeground": "#949494",
    "list.inactiveSelectionForeground": "#7e7e7e",
    "list.hoverForeground": "#949494",
    "list.highlightForeground": "#949494",
    "breadcrumb.foreground": "#888888",
    "breadcrumb.focusForeground": "#949494",
    "breadcrumb.activeSelectionForeground": "#949494",
    // --- エディタハイライト ---
    "editor.lineHighlightBackground": "#ffffff08",
    "editor.lineHighlightBorder": "#00000000",
    "editor.selectionBackground": "#ffffff1a",
    "editor.inactiveSelectionBackground": "#ffffff0d",
    "editor.selectionHighlightBackground": "#ffffff15",
    "editor.wordHighlightBackground": "#ffffff1a",
    "editor.wordHighlightStrongBackground": "#ffffff22",
    "editor.findMatchBackground": "#af704660",
    "editor.findMatchHighlightBackground": "#af704630",
    "editorBracketMatch.background": "#ffffff12",
    "editorBracketMatch.border": "#ffffff30",
    "editorLineNumber.foreground": "#505050",
    "editorLineNumber.activeForeground": "#8d8a8a",
    "editorCursor.foreground": "#8d8a8a",
    "editorError.foreground": "#af7272",
    "editorWarning.foreground": "#89855f",
    "editorInfo.foreground": "#5e8d9e",
    "editorBracketHighlight.foreground1": "#5e8d9e",
    "editorBracketHighlight.foreground2": "#89855f",
    "editorBracketHighlight.foreground3": "#9578a1",
    "editorBracketHighlight.foreground4": "#5e8d9e",
    "editorBracketHighlight.foreground5": "#89855f",
    "editorBracketHighlight.foreground6": "#9578a1",
    "editorBracketHighlight.unexpectedBracket.foreground": "#af7272"
  },
  "tokenColors": [
    {
      "name": "1. Variables & Base",
      "scope": [
        "variable",
        "support.variable",
        "text",
        "source"
      ],
      "settings": {
        "foreground": "#8d8a8a" // L* = 57%
      }
    },
    {
      "name": "2. Functions & Modifiers",
      "scope": [
        "entity.name.function",
        "storage.type",
        "storage.modifier"
      ],
      "settings": {
        "foreground": "#5e8d9e" // [補正] L* = 56%
      }
    },
    {
      "name": "3. Types & Classes",
      "scope": [
        "support.type",
        "storage.type"
      ],
      "settings": {
        "foreground": "#50955e" // [補正] L* = 56%
      }
    },
    {
      "name": "#4. Strings",
      "scope": [
        "string",
        "punctuation.definition.string"
      ],
      "settings": {
        "foreground": "#a47b59" // [補正] L* = 54%
      }
    },
    {
      "name": "5. Keywords",
      "scope": [
        "keyword.control",
        "meta.preprocessor",
        "keyword.control.directive",
        "punctuation.definition.directive",
        "constant.language"
      ],
      "settings": {
        "foreground": "#9578a1" // [補正] L* = 55%
      }
    },
    {
      "name": "6. Numbers",
      "scope": [
        "constant.numeric"
      ],
      "settings": {
        "foreground": "#a97272" // [補正] L* = 53%
      }
    },
    {
      "name": "7. Punctuation",
      "scope": [
        "punctuation"
      ],
      "settings": {
        "foreground": "#8d8a8a"
      }
    },
    {
      "name": "operators",
      "scope": [
        "keyword.operator"
      ],
      "settings": {
        "foreground": "#89855f" // [補正] L* = 55%
      }
    },
    {
      "name": "Comments",
      "scope": [
        "comment",
        "punctuation.definition.comment"
      ],
      "settings": {
        "foreground": "#707070" // L* = 47% (テキストとの差を10%維持)
      }
    }
  ]
}