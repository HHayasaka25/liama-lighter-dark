{
  "name": "Lighter Dark - Zen Perceptual",
  "type": "dark",
  "semanticHighlighting": true,
  "semanticTokenColors": {
    "namespace": "#979595",
    "property": "#979595",
    "class": "#478453",
    "struct": "#478453",
    "type": "#478453",
    "enum": "#478453",
    "enumMember": {
      "foreground": "#979595"
    },
    "variable.constant": {
      "foreground": "#8f5b3c"
    },
    "variable.defaultLibrary": {
      "foreground": "#7e7b58"
    }
  },
  "colors": {
    "editor.background": "#1e1e1e",
    "editor.foreground": "#979595",
    // --- 背景色の完全統一 ---
    "sideBar.background": "#1e1e1e",
    "activityBar.background": "#1e1e1e",
    "statusBar.background": "#1e1e1e",
    "panel.background": "#1e1e1e",
    "tab.activeBackground": "#1e1e1e",
    "tab.inactiveBackground": "#1e1e1e",
    "editorGroupHeader.tabsBackground": "#1e1e1e",
    "titleBar.activeBackground": "#1e1e1e",
    "titleBar.inactiveBackground": "#1e1e1e",
    "editorWidget.background": "#1e1e1e",
    "quickInput.background": "#1e1e1e",
    "breadcrumb.background": "#1e1e1e",
    "menu.background": "#2d2d2d",
    "menu.selectionBackground": "#3a3a3a",
    "menu.selectionForeground": "#ffffff",
    "menu.separatorBackground": "#454545",
    // --- 境界線 ---
    "sideBar.border": "#282828",
    "activityBar.border": "#282828",
    "panel.border": "#282828",
    "statusBar.border": "#282828",
    "editorGroup.border": "#282828",
    "editorWidget.border": "#282828",
    "tab.border": "#1e1e1e",
    "tab.activeBorder": "#979595",
    "tab.activeBorderTop": "#1e1e1e",
    // --- 基本のUI文字色 ---
    "sideBar.foreground": "#7b7b7b",
    "statusBar.foreground": "#6a6a6a",
    "tab.activeForeground": "#979595",
    "tab.inactiveForeground": "#6a6a6a",
    "panelTitle.activeForeground": "#979595",
    "panelTitle.inactiveForeground": "#6a6a6a",
    "titleBar.activeForeground": "#7b7b7b",
    "titleBar.inactiveForeground": "#595959",
    "menu.foreground": "#cccccc",
    "descriptionForeground": "#6a6a6a",
    // ========================================================
    // ▼ 今回の修正：ボタンの明度を少し下げ、文字を黒抜き（#1e1e1e）に変更
    // ========================================================
    "button.background": "#956eb5",
    "button.foreground": "#1e1e1e",
    "button.hoverBackground": "#a780c9",
    // ========================================================
    // ▼ バッジやリンクなどは「元のキーワードの紫」
    "badge.background": "#7f6589",
    "badge.foreground": "#1e1e1e",
    "activityBarBadge.background": "#7f6589",
    "activityBarBadge.foreground": "#1e1e1e",
    "textLink.foreground": "#7f6589",
    "textLink.activeForeground": "#979595",
    "inputOption.activeBorder": "#7f6589",
    // ▼ セカンダリボタン（キャンセルなど）は目立たないグレーのまま
    "button.secondaryBackground": "#222222",
    "button.secondaryForeground": "#7b7b7b",
    "button.secondaryHoverBackground": "#282828",
    "focusBorder": "#282828",
    "input.background": "#2a2a2a",
    "input.foreground": "#979595",
    "input.border": "#454545",
    "dropdown.background": "#1e1e1e",
    "dropdown.foreground": "#979595",
    "dropdown.border": "#282828",
    "checkbox.background": "#1e1e1e",
    "checkbox.foreground": "#979595",
    "checkbox.border": "#282828",
    // --- エクスプローラーのGit色・アイコン ---
    "gitDecoration.modifiedResourceForeground": "#7b7b7b",
    "gitDecoration.untrackedResourceForeground": "#7b7b7b",
    "gitDecoration.addedResourceForeground": "#7b7b7b",
    "gitDecoration.conflictingResourceForeground": "#845c5c",
    "gitDecoration.deletedResourceForeground": "#845c5c",
    "gitDecoration.ignoredResourceForeground": "#434343",
    "icon.foreground": "#595959",
    "tree.indentGuidesStroke": "#282828",
    "tree.inactiveIndentGuidesStroke": "#222222",
    // --- ステータスバー ---
    "statusBarItem.prominentBackground": "#1e1e1e",
    "statusBarItem.prominentForeground": "#6a6a6a",
    "statusBarItem.remoteBackground": "#1e1e1e",
    "statusBarItem.remoteForeground": "#6a6a6a",
    "statusBarItem.hoverBackground": "#282828",
    "activityBar.foreground": "#979595",
    "activityBar.inactiveForeground": "#484848",
    "activityBar.activeBorder": "#1e1e1e",
    // --- ホバーや選択のハイライト ---
    "list.hoverBackground": "#ffffff0a",
    "list.inactiveSelectionBackground": "#ffffff0a",
    "list.activeSelectionBackground": "#ffffff14",
    "list.activeSelectionForeground": "#979595",
    "list.inactiveSelectionForeground": "#7b7b7b",
    "list.hoverForeground": "#979595",
    "list.highlightForeground": "#979595",
    "breadcrumb.foreground": "#6a6a6a",
    "breadcrumb.focusForeground": "#979595",
    "breadcrumb.activeSelectionForeground": "#979595",
    // --- エディタ内のハイライト ---
    "editor.lineHighlightBackground": "#ffffff08",
    "editor.lineHighlightBorder": "#00000000",
    "editor.selectionBackground": "#ffffff1a",
    "editor.inactiveSelectionBackground": "#ffffff0d",
    "editor.selectionHighlightBackground": "#ffffff15",
    "editor.wordHighlightBackground": "#ffffff1a",
    "editor.wordHighlightStrongBackground": "#ffffff22",
    "editor.findMatchBackground": "#8f5b3c60",
    "editor.findMatchHighlightBackground": "#8f5b3c30",
    "editorBracketMatch.background": "#ffffff12",
    "editorBracketMatch.border": "#ffffff30",
    "editorLineNumber.foreground": "#434343",
    "editorLineNumber.activeForeground": "#979595",
    "editorCursor.foreground": "#979595",
    "editorError.foreground": "#935757",
    "editorWarning.foreground": "#8c7c51",
    "editorInfo.foreground": "#547e8d",
    "editorBracketHighlight.foreground1": "#547e8d",
    "editorBracketHighlight.foreground2": "#7e7b58",
    "editorBracketHighlight.foreground3": "#7f6589",
    "editorBracketHighlight.foreground4": "#547e8d",
    "editorBracketHighlight.foreground5": "#7e7b58",
    "editorBracketHighlight.foreground6": "#7f6589",
    "editorBracketHighlight.unexpectedBracket.foreground": "#845c5c"
  },
  "tokenColors": [
    {
      "name": "1. Variables & Base",
      "scope": [
        "variable",
        "support.variable",
        "text",
        "source"
      ],
      "settings": {
        "foreground": "#979595"
      }
    },
    {
      "name": "2. Functions & Modifiers",
      "scope": [
        "entity.name.function",
        "storage.type",
        "storage.modifier"
      ],
      "settings": {
        "foreground": "#547e8d"
      }
    },
    {
      "name": "3. Types & Classes",
      "scope": [
        "support.type",
        "storage.type"
      ],
      "settings": {
        "foreground": "#478453"
      }
    },
    {
      "name": "4. Strings",
      "scope": [
        "string",
        "punctuation.definition.string"
      ],
      "settings": {
        "foreground": "#89694d"
      }
    },
    {
      "name": "5. Keywords",
      "scope": [
        "keyword.control",
        "meta.preprocessor",
        "keyword.control.directive",
        "punctuation.definition.directive",
        "constant.language"
      ],
      "settings": {
        "foreground": "#7f6589"
      }
    },
    {
      "name": "6. Numbers",
      "scope": [
        "constant.numeric"
      ],
      "settings": {
        "foreground": "#845c5c"
      }
    },
    {
      "name": "7. Punctuation",
      "scope": [
        "punctuation"
      ],
      "settings": {
        "foreground": "#979595"
      }
    },
    {
      "name": "operators",
      "scope": [
        "keyword.operator"
      ],
      "settings": {
        "foreground": "#7e7b58"
      }
    },
    {
      "name": "Comments",
      "scope": [
        "comment",
        "punctuation.definition.comment"
      ],
      "settings": {
        "foreground": "#595959"
      }
    }
  ]
}