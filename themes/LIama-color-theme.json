{
  "name": "Lighter Dark - Zen Perceptual",
  "type": "dark",
  "semanticHighlighting": true,
  "semanticTokenColors": {
    "namespace": "#a6a3a3", // [基準] 知覚明度 (L*) = 15% アップから微調整
    "property": "#a6a3a3", // [基準] 知覚明度 (L*) = 15% アップから微調整
    "class": "#4b8c58", // [補正] 彩度による明るさを抑えるため L* = 54% へ
    "struct": "#4b8c58", // [補正] L* = 54%
    "type": "#4b8c58", // [補正] L* = 54%
    "enum": "#4b8c58", // [補正] L* = 54%
    "enumMember": {
      "foreground": "#a6a3a3"
    },
    "variable.constant": {
      "foreground": "#a86a42" // [補正] H-K効果による眩しさを抑えるため L* = 50% へ
    },
    "variable.defaultLibrary": {
      "foreground": "#817e5a" // [補正] 黄色は非常に明るく感じるため L* = 53% へ
    }
  },
  "colors": {
    "editor.background": "#1e1e1e",
    "editor.foreground": "#a6a3a3", // 知覚的明度 (L*) = 55%
    // --- 背景色 ---
    "sideBar.background": "#1e1e1e",
    "activityBar.background": "#1e1e1e",
    "statusBar.background": "#1e1e1e",
    "panel.background": "#1e1e1e",
    "tab.activeBackground": "#1e1e1e",
    "tab.inactiveBackground": "#1e1e1e",
    "editorGroupHeader.tabsBackground": "#1e1e1e",
    "titleBar.activeBackground": "#1e1e1e",
    "titleBar.inactiveBackground": "#1e1e1e",
    "editorWidget.background": "#252525",
    "quickInput.background": "#252525",
    "quickInput.foreground": "#929292",
    "quickInputList.focusBackground": "#333333",
    "quickInputList.focusForeground": "#929292",
    "breadcrumb.background": "#1e1e1e",
    "menu.background": "#252525",
    "menu.selectionBackground": "#333333",
    "menu.selectionForeground": "#929292",
    "menu.separatorBackground": "#383838",
    // --- 通知・エラー表示 ---
    "notifications.background": "#252525",
    "notifications.foreground": "#929292",
    "notifications.border": "#383838",
    "notificationsErrorIcon.foreground": "#af6868",
    "notificationsWarningIcon.foreground": "#a69460",
    "notificationsInfoIcon.foreground": "#6496a8",
    // --- 境界線 ---
    "sideBar.border": "#282828",
    "activityBar.border": "#282828",
    "panel.border": "#282828",
    "statusBar.border": "#282828",
    "editorGroup.border": "#282828",
    "editorWidget.border": "#282828",
    "tab.border": "#1e1e1e",
    "tab.activeBorder": "#a6a3a3",
    "tab.activeBorderTop": "#1e1e1e",
    // --- UI文字色 ---
    "sideBar.foreground": "#929292",
    "statusBar.foreground": "#858585",
    "tab.activeForeground": "#929292",
    "tab.inactiveForeground": "#858585",
    "panelTitle.activeForeground": "#929292",
    "panelTitle.inactiveForeground": "#858585",
    "titleBar.activeForeground": "#929292",
    "titleBar.inactiveForeground": "#747474",
    "menu.foreground": "#929292",
    "descriptionForeground": "#858585",
    // --- ボタン・アクセント ---
    "button.background": "#8e729a", // [補正] 紫の彩度を考慮し L* = 53%
    "button.foreground": "#1e1e1e",
    "button.hoverBackground": "#a083ad",
    "badge.background": "#8e729a",
    "badge.foreground": "#1e1e1e",
    "activityBarBadge.background": "#8e729a",
    "activityBarBadge.foreground": "#1e1e1e",
    "textLink.foreground": "#8e729a",
    "textLink.activeForeground": "#a6a3a3",
    "inputOption.activeBorder": "#8e729a",
    // --- その他UI ---
    "button.secondaryBackground": "#222222",
    "button.secondaryForeground": "#929292",
    "button.secondaryHoverBackground": "#282828",
    "focusBorder": "#282828",
    "input.background": "#2a2a2a",
    "input.foreground": "#929292",
    "input.border": "#454545",
    "dropdown.background": "#1e1e1e",
    "dropdown.foreground": "#929292",
    "dropdown.border": "#282828",
    "checkbox.background": "#1e1e1e",
    "checkbox.foreground": "#929292",
    "checkbox.border": "#282828",
    "gitDecoration.modifiedResourceForeground": "#929292",
    "gitDecoration.untrackedResourceForeground": "#929292",
    "gitDecoration.addedResourceForeground": "#929292",
    "gitDecoration.conflictingResourceForeground": "#af6868",
    "gitDecoration.deletedResourceForeground": "#af6868",
    "gitDecoration.ignoredResourceForeground": "#555555",
    "icon.foreground": "#747474",
    "tree.indentGuidesStroke": "#282828",
    "tree.inactiveIndentGuidesStroke": "#222222",
    "statusBarItem.prominentBackground": "#1e1e1e",
    "statusBarItem.prominentForeground": "#858585",
    "statusBarItem.remoteBackground": "#1e1e1e",
    "statusBarItem.remoteForeground": "#858585",
    "statusBarItem.hoverBackground": "#282828",
    "activityBar.foreground": "#929292",
    "activityBar.inactiveForeground": "#555555",
    "activityBar.activeBorder": "#1e1e1e",
    "list.activeSelectionForeground": "#929292",
    "list.inactiveSelectionForeground": "#7b7b7b",
    "list.hoverForeground": "#929292",
    "list.highlightForeground": "#929292",
    "breadcrumb.foreground": "#858585",
    "breadcrumb.focusForeground": "#929292",
    "breadcrumb.activeSelectionForeground": "#929292",
    // --- エディタハイライト ---
    "editor.lineHighlightBackground": "#ffffff08",
    "editor.lineHighlightBorder": "#00000000",
    "editor.selectionBackground": "#ffffff1a",
    "editor.inactiveSelectionBackground": "#ffffff0d",
    "editor.selectionHighlightBackground": "#ffffff15",
    "editor.wordHighlightBackground": "#ffffff1a",
    "editor.wordHighlightStrongBackground": "#ffffff22",
    "editor.findMatchBackground": "#a86a4260",
    "editor.findMatchHighlightBackground": "#a86a4230",
    "editorBracketMatch.background": "#ffffff12",
    "editorBracketMatch.border": "#ffffff30",
    "editorLineNumber.foreground": "#4c4c4c",
    "editorLineNumber.activeForeground": "#a6a3a3",
    "editorCursor.foreground": "#a6a3a3",
    "editorError.foreground": "#af6868",
    "editorWarning.foreground": "#a69460",
    "editorInfo.foreground": "#6496a8",
    "editorBracketHighlight.foreground1": "#6496a8",
    "editorBracketHighlight.foreground2": "#a29e71",
    "editorBracketHighlight.foreground3": "#8e729a",
    "editorBracketHighlight.foreground4": "#6496a8",
    "editorBracketHighlight.foreground5": "#a29e71",
    "editorBracketHighlight.foreground6": "#8e729a",
    "editorBracketHighlight.unexpectedBracket.foreground": "#af6868"
  },
  "tokenColors": [
    {
      "name": "1. Variables & Base",
      "scope": [
        "variable",
        "support.variable",
        "text",
        "source"
      ],
      "settings": {
        "foreground": "#a6a3a3" // L* = 55%
      }
    },
    {
      "name": "2. Functions & Modifiers",
      "scope": [
        "entity.name.function",
        "storage.type",
        "storage.modifier"
      ],
      "settings": {
        "foreground": "#598696" // [補正] L* = 54%
      }
    },
    {
      "name": "3. Types & Classes",
      "scope": [
        "support.type",
        "storage.type"
      ],
      "settings": {
        "foreground": "#4b8c58" // [補正] L* = 54%
      }
    },
    {
      "name": "4. Strings",
      "scope": [
        "string",
        "punctuation.definition.string"
      ],
      "settings": {
        "foreground": "#9a7554" // [補正] 暖色かつ中程度の彩度を考慮し L* = 52%
      }
    },
    {
      "name": "5. Keywords",
      "scope": [
        "keyword.control",
        "meta.preprocessor",
        "keyword.control.directive",
        "punctuation.definition.directive",
        "constant.language"
      ],
      "settings": {
        "foreground": "#8e729a" // [補正] 高彩度の紫を考慮し L* = 53%
      }
    },
    {
      "name": "6. Numbers",
      "scope": [
        "constant.numeric"
      ],
      "settings": {
        "foreground": "#a26f6f" // [補正] 赤系の進出性を抑えるため L* = 51%
      }
    },
    {
      "name": "7. Punctuation",
      "scope": [
        "punctuation"
      ],
      "settings": {
        "foreground": "#a6a3a3"
      }
    },
    {
      "name": "operators",
      "scope": [
        "keyword.operator"
      ],
      "settings": {
        "foreground": "#817e5a" // [補正] 演算子(黄色)を L* = 53% に抑制
      }
    },
    {
      "name": "Comments",
      "scope": [
        "comment",
        "punctuation.definition.comment"
      ],
      "settings": {
        "foreground": "#6b6b6b" // L* = 45%
      }
    }
  ]
}