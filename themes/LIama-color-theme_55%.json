{
  "name": "Lighter Dark - Zen Perceptual 55",
  "type": "dark",
  "semanticHighlighting": true,
  "semanticTokenColors": {
    "namespace": "#8b8888",
    "property": "#8b8888",
    "class": "#42754c",
    "struct": "#42754c",
    "type": "#42754c",
    "enum": "#42754c",
    "enumMember": {
      "foreground": "#8b8888"
    },
    "variable.constant": {
      "foreground": "#865757"
    },
    "variable.defaultLibrary": {
      "foreground": "#817d5c"
    }
  },
  "colors": {
    "editor.background": "#212121",
    "editor.foreground": "#8b8888",
    "sideBar.background": "#212121",
    "activityBar.background": "#212121",
    "statusBar.background": "#212121",
    "panel.background": "#212121",
    "tab.activeBackground": "#212121",
    "tab.inactiveBackground": "#212121",
    "editorGroupHeader.tabsBackground": "#212121",
    "titleBar.activeBackground": "#212121",
    "titleBar.inactiveBackground": "#212121",
    "editorWidget.background": "#282828",
    "quickInput.background": "#282828",
    "tab.activeBorder": "#8b8888",
    "editorLineNumber.activeForeground": "#8b8888",
    "editorCursor.foreground": "#8b8888",
    "editorError.foreground": "#865757",
    "editorWarning.foreground": "#817d5c",
    "editorInfo.foreground": "#45717e",
    "editorBracketHighlight.foreground1": "#45717e",
    "editorBracketHighlight.foreground2": "#817d5c",
    "editorBracketHighlight.foreground3": "#755e7f",
    "editorBracketHighlight.foreground4": "#45717e",
    "editorBracketHighlight.foreground5": "#817d5c",
    "editorBracketHighlight.foreground6": "#755e7f",
    "editorBracketHighlight.unexpectedBracket.foreground": "#865757",
    "sideBar.foreground": "#8b8888",
    "sideBarSectionHeader.foreground": "#8b8888",
    "sideBarTitle.foreground": "#8b8888",
    "tab.activeForeground": "#8b8888",
    "tab.inactiveForeground": "#8b8888",
    "list.activeSelectionForeground": "#8b8888",
    "list.inactiveSelectionForeground": "#8b8888",
    "list.hoverForeground": "#8b8888",
    "quickInput.foreground": "#8b8888",
    "statusBar.foreground": "#5c5c5c",
    "activityBar.foreground": "#8b8888",
    "activityBar.inactiveForeground": "#5c5c5c",
    "titleBar.activeForeground": "#8b8888",
    "menu.foreground": "#8b8888",
    "menubar.selectionForeground": "#8b8888",
    "panelTitle.activeForeground": "#8b8888",
    "panelTitle.inactiveForeground": "#8b8888",
    "panel.foreground": "#8b8888",
    "terminal.background": "#212121",
    "terminal.foreground": "#8b8888",
    "terminal.ansiBlack": "#212121",
    "terminal.ansiBrightBlack": "#5c5c5c",
    "terminal.ansiRed": "#d45959",
    "terminal.ansiBrightRed": "#d45959",
    "terminal.ansiGreen": "#089660",
    "terminal.ansiBrightGreen": "#089660",
    "terminal.ansiYellow": "#8d8d05",
    "terminal.ansiBrightYellow": "#8d8d05",
    "terminal.ansiBlue": "#3b88df",
    "terminal.ansiBrightBlue": "#3b88df",
    "terminal.ansiMagenta": "#c95cc9",
    "terminal.ansiBrightMagenta": "#c95cc9",
    "terminal.ansiCyan": "#0d8cae",
    "terminal.ansiBrightCyan": "#0d8cae",
    "terminal.ansiWhite": "#8b8888",
    "terminal.ansiBrightWhite": "#8b8888"
  },
  "tokenColors": [
    {
      "name": "Base",
      "scope": [
        "variable",
        "support.variable",
        "text",
        "source",
        "punctuation"
      ],
      "settings": {
        "foreground": "#8b8888"
      }
    },
    {
      "name": "Function",
      "scope": [
        "entity.name.function",
        "storage.type",
        "storage.modifier"
      ],
      "settings": {
        "foreground": "#45717e"
      }
    },
    {
      "name": "Keyword",
      "scope": [
        "keyword.control",
        "meta.preprocessor",
        "punctuation.definition.keyword",
        "punctuation.definition.directive",
        "punctuation.definition.tag",
        "constant.language"
      ],
      "settings": {
        "foreground": "#755e7f"
      }
    },
    {
      "name": "String",
      "scope": [
        "string",
        "punctuation.definition.string"
      ],
      "settings": {
        "foreground": "#936d4f"
      }
    },
    {
      "name": "Number",
      "scope": [
        "constant.numeric"
      ],
      "settings": {
        "foreground": "#865757"
      }
    },
    {
      "name": "Comment",
      "scope": [
        "comment",
        "punctuation.definition.comment"
      ],
      "settings": {
        "foreground": "#5c5c5c"
      }
    },
    {
      "name": "C++ Standard Streams and Shift Operators",
      "scope": [
        "support.variable.mains.cpp",
        "support.variable.mains.c",
        "keyword.operator.shift.cpp",
        "keyword.operator.shift.c"
      ],
      "settings": {
        "foreground": "#817d5c"
      }
    }
  ]
}